<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>个人主页</title>
  <!-- 样式写在 style 标签里，这叫"内嵌 CSS" -->
  <style>
    /* ===== 全局重置：让所有元素的边距归零 ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* ===== 页面背景和字体 ===== */
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background-color: #f5f5f5;
      color: #333;
      line-height: 1.6;
      scroll-behavior: smooth;
    }

    /* ===== 顶部区域（Hero） ===== */
    .hero {
      background: linear-gradient(135deg, hsl(247, 53%, 45%), hsl(67, 82%, 46%));
      color: white;
      text-align: center;
      padding: 80px 20px;
      background-size: 200% 200%;
      animation: gradientShift 8s ease infinite;
      position: relative;
      overflow: hidden;
    }

    @keyframes gradientShift {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .hero::before {
      content: "";
      position: absolute;
      top: -60px;
      right: -60px;
      width: 200px;
      height: 200px;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
    }

    .hero::after {
      content: "";
      position: absolute;
      bottom: -40px;
      left: -40px;
      width: 150px;
      height: 150px;
      border-radius: 50%;
      background: rgba(255,255,255,0.06);
    }

    /* ===== 头像样式 ===== */
    .avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      border: 4px solid white;
      object-fit: cover;
      margin-bottom: 20px;
      display: block;
      margin-left: auto;
      margin-right: auto;
    }

    .hero h1 {
      font-size: 48px;
      margin-bottom: 10px;
    }

    .hero p {
      font-size: 20px;
      opacity: 0.9;
    }

    /* ===== 内容区块通用样式 ===== */
    .section {
      max-width: 800px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .section h2 {
      font-size: 28px;
      margin-bottom: 20px;
      color: #444;
      border-bottom: 3px solid #667eea;
      padding-bottom: 8px;
      display: inline-block;
    }

    /* ===== 技能卡片布局 ===== */
    .skills {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .skill-card {
      background: white;
      border-radius: 8px;
      padding: 16px 24px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      font-weight: 500;
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: default;
    }

    .skill-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }

    /* ===== 项目卡片 ===== */
    .project-list {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }

    .project-card {
      background: white;
      border-radius: 8px;
      padding: 24px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      flex: 1;
      min-width: 200px;
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: pointer;
    }

    .project-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    }

    .project-card h3 {
      margin-bottom: 8px;
      color: #333;
    }

    .project-card p {
      font-size: 14px;
      color: #666;
    }

    /* ===== 底部联系信息 ===== */
    .footer {
      text-align: center;
      padding: 40px 20px;
      background: #333;
      color: white;
      margin-top: 60px;
    }

    .footer a {
      color: #a8b5ff;
      text-decoration: none;
    }

      .footer a:hover {
    }

    .footer::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #667eea, #764ba2);
    }
        text-decoration: underline;
      }

      .footer {
        position: relative;
        overflow: hidden;
      }


    /* ===== 夜间模式 ===== */
    .dark-mode {
      background-color: #1a1a2e;
      color: #eee;
    }

    .dark-mode .section h2 {
      color: #ccc;
      border-bottom-color: #ff6b6b;
    }

    .dark-mode .skill-card,
    .dark-mode .project-card {
      background: #2a2a3e;
      color: #ddd;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    .dark-mode .project-card h3 {
      color: #eee;
    }

    .dark-mode .project-card p {
      color: #aaa;
    }

    /* ===== 切换按钮 ===== */
    .toggle-btn {
      margin-top: 24px;
      padding: 10px 24px;
      font-size: 16px;
      border: 2px solid white;
      background: transparent;
      color: white;
      border-radius: 6px;
      cursor: pointer;
    }

    .toggle-btn:hover {
      background: rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.2);
      transform: scale(1.05);

    /* ===== 时钟样式 ===== */
    #clock {
      margin-top: 20px;
      font-size: 18px;
      opacity: 0.85;
      font-family: monospace;
      letter-spacing: 2px;
    }

    /* ===== 点赞按钮 ===== */
    .like-btn {
      margin-top: 16px;
      padding: 8px 20px;
      font-size: 16px;
      background: rgba(255,255,255,0.2);
      border: 2px solid white;
      color: white;
      border-radius: 20px;
      cursor: pointer;
      transition: background 0.2s;
    }

    .like-btn:hover {
      background: rgba(255,255,255,0.35);
    }

    .like-count {
      font-size: 20px;
      margin-left: 8px;
      font-weight: bold;
    }
  </style>
</head>
<body>

  <!-- ===== Hero 区域 ===== -->
  <div class="hero">
    <img src="images/avatar.jpg" alt="我的照片" class="avatar" />
    <h1>连展锋</h1>
    <p>集美大学准大一新生 · 正在学编程</p>
    <!-- 切换按钮 -->
    <button class="toggle-btn" onclick="toggleDarkMode()">🌙 夜间模式</button>
    <!-- 实时时钟 -->
    <p id="clock"></p>
    <!-- 点赞计数器 -->
    <div style="margin-top: 8px;">
      <button class="like-btn" onclick="addLike()">❤️ 点赞</button>
      <span class="like-count" id="likeCount">0</span>
    </div>
  </div>

  <!-- ===== 关于我 ===== -->
  <div class="section">
    <h2>关于我</h2>
    <p>
      你好！我是连展锋，2026 年高考生，即将进入集美大学就读。
      这个暑假开始学习前端开发，目标是能用代码做出有用的东西。
    </p>
    <p>
      平时喜欢打篮球、打游戏，也喜欢研究各种效率工具。
    </p>
  </div>

  <!-- ===== 技能 ===== -->
  <div class="section">
    <h2>正在学</h2>
    <div class="skills">
      <div class="skill-card">HTML</div>
      <div class="skill-card">CSS</div>
      <div class="skill-card">JavaScript（即将）</div>
    </div>
  </div>

  <!-- ===== 我的项目 ===== -->
  <div class="section">
    <h2>我的项目</h2>
    <div class="project-list">
      <div class="project-card" onclick="alert('个人主页 - 这是我的第一个网页项目！')">
        <h3>个人主页</h3>
        <p>我的第一个网页项目，用 HTML + CSS 搭建。</p>
      </div>
      <div class="project-card" onclick="alert('正在学习中，敬请期待！')">
        <h3>下一个项目</h3>
        <p>正在学习中，敬请期待！</p>
      </div>
      <div class="project-card" onclick="alert('大学期间会陆续更新！')">
        <h3>更多作品</h3>
        <p>大学期间会陆续更新。</p>
      </div>
    </div>
  </div>

  <!-- ===== 联系方式 ===== -->
  <div class="footer">
    <p>📧 邮箱：<a href="mailto:your-email@example.com">your-email@example.com</a></p>
    <p>📱 GitHub：<a href="https://github.com/your-name" target="_blank">github.com/your-name</a></p>
    <p style="margin-top:16px; font-size:14px; opacity:0.6;">&copy; 2026 连展锋</p>
  </div>

  <!-- ===== JavaScript：放在 body 最末尾，确保页面加载完再执行 ===== -->
  <script>
    // ===== 点赞计数器 =====
    let likes = 0;

    function addLike() {
      likes = likes + 1;
      document.getElementById("likeCount").textContent = likes;
    }

    // ===== 时钟函数：每秒更新一次 =====
    function updateClock() {
      const now = new Date();
      const timeStr = now.toLocaleTimeString("zh-CN", { hour12: false });
      document.getElementById("clock").textContent = "🕐 " + timeStr;
    }

    // 页面加载后立即显示一次
    updateClock();
    // 然后每隔 1 秒（1000 毫秒）更新一次
    setInterval(updateClock, 1000);

    // 定义一个函数：切换夜间模式
    function toggleDarkMode() {
      // 获取 <body> 元素
      const body = document.body;
      // 切换 body 的 dark-mode 类
      // 有就删掉，没有就加上
      body.classList.toggle("dark-mode");

      // 同时改按钮文字
      const btn = document.querySelector(".toggle-btn");
      if (body.classList.contains("dark-mode")) {
        btn.textContent = "☀️ 日间";
      } else {
        btn.textContent = "🌙 夜间";
      }
    }
  </script>

</body>
</html>

